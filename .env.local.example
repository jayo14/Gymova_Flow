# Supabase - Public keys (safe to expose in the browser)
# Find these in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase - Service role key (SERVER-SIDE ONLY - never expose to the browser)
# Find this in: Supabase Dashboard -> Project Settings -> API -> service_role key (secret)
# Required for: admin approval flow (app/admin/*)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini AI API key (server-side only)
# Get a free key at: https://aistudio.google.com (1,500 requests/day, no credit card)
# Required for: AI Coach chatbot (app/ai-coach/*)
GEMINI_API_KEY=your-gemini-api-key

# Optional: override the default OpenStreetMap raster tile server
# Required for: map page (app/map/*)
# NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
