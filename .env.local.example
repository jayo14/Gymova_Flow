# Supabase - Public keys (safe to expose in the browser)
# Find these in: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase - Service role key (SERVER-SIDE ONLY - never expose to the browser)
# Find this in: Supabase Dashboard -> Project Settings -> API -> service_role key (secret)
# Required for: admin approval flow (app/admin/*) and custom email auth flows
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini AI API key (server-side only)
# Get a free key at: https://aistudio.google.com (1,500 requests/day, no credit card)
# Required for: AI Coach chatbot (app/ai-coach/*)
GEMINI_API_KEY=your-gemini-api-key

# Resend API key (server-side only) — used for all transactional emails
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# Email from address — must match a verified domain in your Resend account
EMAIL_FROM=noreply@mail.gymovaflow.com

# SMTP settings (uses Resend's SMTP relay as a fallback)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key

# Public site URL — used to construct absolute URLs in emails (e.g., password reset links)
# Set this to your production domain or leave empty for automatic detection
NEXT_PUBLIC_SITE_URL=https://gymovaflow.com

# Optional: override the default OpenStreetMap raster tile server
# Required for: map page (app/map/*)
# NEXT_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
